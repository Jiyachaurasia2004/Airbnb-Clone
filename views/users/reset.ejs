<!DOCTYPE html>
<html>
<head>
  <title>Reset Password</title>
</head>
<body>
  <div class="container">
    <h2>Reset Your Password</h2>
    <form action="/users/reset" method="POST">
      <label>New Password:</label>
      <input type="password" name="password" required>
      <button type="submit">Reset Password</button>
    </form>
  </div>
</body>
</html>
